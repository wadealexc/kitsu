{
    "llamaCpp": {
        "sleepAfterXSeconds": 600
    },
    "web": {
        "enable": false,
        "braveAPIKey": "",
        "runDangerouslyWithoutSandbox": false,
        "screenshotWebpages": false
    },
    "ports": {
        "llamaCpp": {
            "port": 8080,
            "host": "192.168.87.30"
        },
        "shim": {
            "port": 8081,
            "host": "192.168.87.30"
        },
        "taskModel": {
            "port": 8090,
            "host": "192.168.87.30"
        }
    },
    "logs": {
        "path": "./logs",
        "enable": false
    },
    "models": {
        "path": "./models",
        "onStart": "qwen3-vl-30b",
        "models": [
            {
                "gguf": "qwen3-vl-30b/Qwen3-VL-30B-A3B-Thinking-Q6_K",
                "mmproj": "qwen3-vl-30b/mmproj-BF16",
                "alias": "qwen3-vl-30b",
                "args": [
                    "--ctx-size",
                    50000
                ]
            },
            {
                "gguf": "gpt-oss-20b/gpt-oss-20b-mxfp4",
                "alias": "gpt-oss-20b",
                "args": [
                    "--ctx-size",
                    0
                ]
            }
        ],
        "taskModel": {
            "gguf": "taskModels/Qwen3-4B-Instruct-2507-Q4_K_S",
            "alias": "qwen3-4b-ins",
            "args": [
                "--ctx-size",
                8192
            ],
            "params": {
                "temperature": 0.7,
                "top_p": 0.8,
                "top_k": 20,
                "min_p": 0.0,
                "presence_penalty": 1.0,
                "chat_template_kwargs": {
                    "enable_thinking": false
                }
            }
        }
    }
}